{
  "manifest_version": 3,
  "name": "WeLib Bypass",
  "version": "1.0",
  "description": "Bypass welib.org limit",
  "permissions": ["webRequest", "downloads", "storage"],
  "host_permissions": [
    "*://*.welib-premium.org/*",
    "*://*.welib-public.org/*",
    "*://welib-premium.org/*",
    "*://welib-public.org/*",
    "*://welib.org/*",
    "*://*.welib.org/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": [
      "*://*.welib-premium.org/*",
      "*://*.welib-public.org/*",
      "*://welib-premium.org/*",
      "*://welib-public.org/*",
      "*://welib.org/*",
      "*://*.welib.org/*"
    ],
    "js": ["content.js"],
    "run_at": "document_start",
    "all_frames": false
  }],
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
